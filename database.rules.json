{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (auth.uid === $uid && (!data.exists() ? newData.child('role').val() === 'worker' && newData.child('active').val() === true : newData.child('role').val() === data.child('role').val() && newData.child('active').val() === data.child('active').val())))"
      }
    },
    "pendingUsers": {
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$emailKey": {
        ".read": "auth != null"
      }
    },
    "projectAssignments": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "projects":  { ".read": "auth != null", ".write": "auth != null" },
    "reports":   { ".read": "auth != null", ".write": "auth != null" },
    "documents": { ".read": "auth != null", ".write": "auth != null" },
    "drives":    { ".read": "auth != null", ".write": "auth != null" },
    "costs":     { ".read": "auth != null", ".write": "auth != null" }
  }
}
