{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "projectAssignments": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },
    "projects":  { ".read": "auth != null", ".write": "auth != null" },
    "reports":   { ".read": "auth != null", ".write": "auth != null" },
    "documents": { ".read": "auth != null", ".write": "auth != null" },
    "drives":    { ".read": "auth != null", ".write": "auth != null" },
    "costs":     { ".read": "auth != null", ".write": "auth != null" }
  }
}
